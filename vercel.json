{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/newsletter-:slug([a-z]+-[0-9]+-[0-9]+.*)",
      "destination": "/newsletter-detail"
    },
    {
      "source": "/article-:slug([a-z0-9].*)",
      "destination": "/article"
    },
    {
      "source": "/book-note-:slug([a-z0-9].*)",
      "destination": "/book-note"
    }
  ]
}
